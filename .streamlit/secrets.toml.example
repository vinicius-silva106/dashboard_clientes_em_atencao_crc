# Configuração da conexão com o Google Sheets
# Renomeie este arquivo para "secrets.toml" e preencha com seus dados.

[connections.gsheets]
# URL completa da planilha do Google Sheets (deve estar com acesso público ou compartilhada com a Service Account)
spreadsheet = "https://docs.google.com/spreadsheets/d/SEU_ID_AQUI/edit"

# Tipo fixo para streamlit-gsheets
type = "gsheets"

# -----------------------------------------------------------------------
# AUTENTICAÇÃO VIA SERVICE ACCOUNT (recomendado para produção)
# -----------------------------------------------------------------------
# Se a planilha NÃO for pública, preencha os campos abaixo com as
# credenciais da Service Account (JSON do Google Cloud).
#
# [connections.gsheets]
# spreadsheet   = "https://docs.google.com/spreadsheets/d/SEU_ID_AQUI/edit"
# type          = "gsheets"
# private_key_id       = "..."
# private_key          = "-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
# client_email         = "nome@projeto.iam.gserviceaccount.com"
# client_id            = "..."
# auth_uri             = "https://accounts.google.com/o/oauth2/auth"
# token_uri            = "https://oauth2.googleapis.com/token"
